# Copy this file to backend/.env (same folder as server.js) — NOT node_modules/.env
# .env is ignored by Git — never commit API keys.

# WhoisXML API key: https://www.whoisxmlapi.com/
WHOIS_API_KEY=your_whoisxml_api_key_here

# Google Safe Browsing API key: https://console.cloud.google.com/apis/credentials
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key_here

# Optional: change the backend port (default 3001)
# PORT=3001
